{
  "libraries": [
    {
      "component_count": 1,
      "depends_on": ["@gravity-ui/page-constructor", "@gravity-ui/uikit"],
      "id": "blog-constructor",
      "is_peer_dependency_of": [],
      "package": "@gravity-ui/blog-constructor",
      "purpose": "Blog page construction components. Provides PromptSignIn for gating blog interactions behind authentication."
    },
    {
      "component_count": 18,
      "depends_on": ["@gravity-ui/uikit"],
      "id": "components",
      "is_peer_dependency_of": [],
      "package": "@gravity-ui/components",
      "purpose": "Extended component library built on top of uikit. Includes adaptive tabs, changelog dialogs, confirm dialogs, cookie consent, form helpers, galleries, infinite scroll, item selectors, notifications, onboarding, promo sheets, reactions, share popovers, store badges, and stories."
    },
    {
      "component_count": 6,
      "depends_on": ["@gravity-ui/date-utils", "@gravity-ui/uikit"],
      "id": "date-components",
      "is_peer_dependency_of": [],
      "package": "@gravity-ui/date-components",
      "purpose": "Date and time picking components. Provides Calendar, DateField, DatePicker, RangeCalendar, RelativeDateField, and RelativeDatePicker with support for absolute and Grafana-style relative dates."
    },
    {
      "component_count": 7,
      "depends_on": ["@gravity-ui/icons", "@gravity-ui/uikit"],
      "id": "navigation",
      "is_peer_dependency_of": [],
      "package": "@gravity-ui/navigation",
      "purpose": "Application navigation components. Provides ActionBar, AsideHeader (sidebar), Footer, HotkeysPanel, Logo, MobileHeader, and Settings panel for building complete application shells."
    },
    {
      "component_count": 6,
      "depends_on": ["@gravity-ui/uikit"],
      "id": "page-constructor",
      "is_peer_dependency_of": ["blog-constructor"],
      "package": "@gravity-ui/page-constructor",
      "purpose": "Landing page and content page construction components. Provides Button, ErrorWrapper, Link, Map, Table, and Title for building marketing and documentation pages."
    },
    {
      "component_count": 1,
      "depends_on": ["@gravity-ui/i18n", "@gravity-ui/icons", "@gravity-ui/uikit"],
      "id": "table",
      "is_peer_dependency_of": [],
      "package": "@gravity-ui/table",
      "purpose": "Advanced data table built on TanStack Table. Provides BaseTable with support for sticky headers/footers, row virtualization, column resizing, grouping, sorting, and custom row rendering."
    },
    {
      "component_count": 57,
      "depends_on": [],
      "id": "uikit",
      "is_peer_dependency_of": ["blog-constructor", "components", "date-components", "navigation", "page-constructor", "table"],
      "package": "@gravity-ui/uikit",
      "purpose": "Core component library providing foundational UI primitives. Includes buttons, form controls, overlays, navigation elements, data display components, typography, layout helpers, and feedback indicators. All other Gravity UI libraries depend on uikit."
    }
  ],
  "system": {
    "branding": "Gravity UI is the design language of Yandex Cloud. It emphasizes functional, accessible interfaces with a focus on information density and developer productivity.",
    "corner_radius": "Uses size-based border-radius tokens. Components support a pin prop for controlling corner rounding with values like round-round, brick-round, clear-clear, allowing fine-grained control over individual corners.",
    "description": "Gravity UI is an open-source design system by Yandex Cloud for building modern React applications. It provides a comprehensive set of components, design tokens, and utilities organized across multiple packages, with @gravity-ui/uikit as the core foundation.",
    "spacing": "Based on a 4px modular grid (--g-spacing-base: 4px). Spacing tokens range from --g-spacing-0 (0px) through --g-spacing-10 (40px), with a half-step at 2px. All spacing values are multiples of the 4px base unit.",
    "theming": "Supports four built-in themes via CSS custom properties: light, dark, light-hc (high contrast), and dark-hc (high contrast). Uses a two-layer color system with private palette values and semantic token aliases. Theme is applied via ThemeProvider and toggled with useTheme hook. Supports system theme detection.",
    "typography": "Uses Inter as the primary sans-serif font with a system font stack fallback (Helvetica Neue, Helvetica, Arial). Monospace uses Menlo, Monaco, Consolas. Provides typography variants: display (4 sizes), header (2 sizes), subheader (3 sizes), body (3 sizes + short), caption (2 sizes), code (3 sizes), and code-inline (3 sizes)."
  },
  "categories": {
    "actions": "Components that trigger operations — buttons, links, dropdowns, menus",
    "ai": "AI chat and assistant components — message bubbles, prompt input, chat layout, ratings",
    "data-display": "Components for presenting structured data — tables, lists, cards, definition lists",
    "feedback": "Components for status and user feedback — alerts, toasters, progress bars, spinners",
    "forms": "Form controls and input components — text fields, selects, checkboxes, date pickers",
    "layout": "Structural and layout components — flex, grid, dividers, containers",
    "navigation": "Navigation and routing components — breadcrumbs, tabs, pagination, aside header",
    "overlays": "Modal surfaces — dialogs, drawers, popovers, tooltips, sheets",
    "typography": "Text display components — text, label, code, display headings",
    "utility": "Utility components and hooks — clipboard, portal, skeleton, hotkeys"
  },
