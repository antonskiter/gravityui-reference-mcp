  {
    "name": "ErrorWrapper",
    "library": "page-constructor",
    "category": "feedback",
    "import_path": "@gravity-ui/page-constructor",
    "import_statement": "import {ErrorWrapper} from '@gravity-ui/page-constructor';",
    "description": "The ErrorWrapper component is used to gracefully handle and display local errors in UI sections. When the isError flag is set to true, it shows an error message and an optional retry button. When isError is false, it renders its children content.",
    "source_file": "vendor/page-constructor/src/components/ErrorWrapper/ErrorWrapper.tsx",
    "props": [
      {
        "name": "buttonText",
        "type": "string",
        "required": true,
        "description": "Text for the retry button"
      },
      {
        "name": "children",
        "type": "React.ReactNode",
        "required": true,
        "description": "Content rendered when no error occurs"
      },
      {
        "name": "handler",
        "type": "() => void",
        "required": true,
        "description": "Callback triggered on retry button click"
      },
      {
        "name": "isError",
        "type": "boolean",
        "required": true,
        "description": "Show error (true) or children (false)"
      },
      {
        "name": "text",
        "type": "string",
        "required": true,
        "description": "Error message text"
      },
      {
        "name": "className",
        "type": "string",
        "required": false,
        "description": "Optional CSS class for additional styling"
      }
    ],
    "examples": [
      "const [isError, setIsError] = React.useState(true);\n\n<ErrorWrapper\n  text=\"Something went wrong\"\n  buttonText=\"Try again\"\n  isError={isError}\n  handler={() => setIsError(false)}\n>\n  <div>Data loaded successfully!</div>\n</ErrorWrapper>"
    ]
  },
