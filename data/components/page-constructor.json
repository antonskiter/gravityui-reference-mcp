  {
    "name": "Button",
    "library": "page-constructor",
    "category": "actions",
    "import_path": "@gravity-ui/page-constructor",
    "import_statement": "import {Button} from '@gravity-ui/page-constructor';",
    "description": "Button component for page-constructor with support for various themes, sizes, and image/icon attachments. Supports App Store and Google Play platform badges.",
    "source_file": "vendor/page-constructor/src/components/Button/Button.tsx",
    "props": [
      {
        "name": "analyticsEvents",
        "type": "AnalyticsEventsBase",
        "required": false,
        "description": "Analytics events to track"
      },
      {
        "name": "className",
        "type": "string",
        "required": false,
        "description": "Additional CSS class"
      },
      {
        "name": "id",
        "type": "string",
        "required": false,
        "description": "HTML id attribute"
      },
      {
        "name": "img",
        "type": "object | string",
        "required": false,
        "description": "Button icon. If string, specify the icon link. If object, specify url, position, alt"
      },
      {
        "name": "onClick",
        "type": "React.MouseEventHandler<HTMLButtonElement | HTMLAnchorElement>",
        "required": false,
        "description": "Click handler"
      },
      {
        "name": "size",
        "type": "'xs' | 's' | 'ns' | 'n' | 'm' | 'l' | 'head' | 'promo'",
        "required": false,
        "default": "l",
        "description": "Button size"
      },
      {
        "name": "text",
        "type": "string",
        "required": false,
        "description": "Button text"
      },
      {
        "name": "theme",
        "type": "'action' | 'clear' | 'link' | 'normal' | 'pseudo' | 'raised' | 'github' | 'app-store' | 'google-play' | 'scale' | 'monochrome'",
        "required": false,
        "default": "normal",
        "description": "Button look and feel"
      },
      {
        "name": "url",
        "type": "string",
        "required": false,
        "description": "Button link URL"
      },
      {
        "name": "urlTitle",
        "type": "string",
        "required": false,
        "description": "Button URL title attribute"
      },
      {
        "name": "width",
        "type": "string",
        "required": false,
        "description": "Button width"
      }
    ],
    "examples": [
      "<Button text=\"Click me\" url=\"https://example.com\" />",
      "<Button text=\"App Store\" theme=\"app-store\" url=\"https://apps.apple.com/app\" />",
      "<Button text=\"GitHub\" theme=\"github\" url=\"https://github.com/gravity-ui\" />"
    ]
