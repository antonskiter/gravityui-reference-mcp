    "id": "component:blog-constructor:promptsignin:description",
    "section_title": "Description",
    "content": "PromptSignIn displays a prompt encouraging unauthenticated users to sign in. It extends the uikit Prompt component with a dedicated sign-in action button. Used in blog contexts to gate interactions like comments or reactions behind authentication."
  },
